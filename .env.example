# ---------------------------------------------------------------------------
# Personalized Email Generator - Environment Variables
# Copy this file to `.env` and adjust values as needed.
# NEVER commit your real .env file.
# ---------------------------------------------------------------------------

# --- Model configuration ---
MODEL_NAME=EleutherAI/gpt-neo-1.3B
TOKENIZER_NAME=EleutherAI/gpt-neo-1.3B

# --- Execution mode ---
# Set to "true" to call the Hugging Face Inference API instead of loading
# the model locally (useful if your machine can't hold a 1.3B model in
# memory). Requires HUGGINGFACEHUB_API_TOKEN below.
USE_INFERENCE_API=false

# Required only if USE_INFERENCE_API=true.
# Get a free token at https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=

# --- Generation hyperparameters ---
MAX_NEW_TOKENS=200
TEMPERATURE=0.9
TOP_K=50
TOP_P=0.95
REPETITION_PENALTY=1.3
NO_REPEAT_NGRAM_SIZE=3

# --- Prompt engineering ---
STOP_DELIMITER=---

# --- App metadata ---
APP_TITLE=Personalized Email Generator
APP_ICON=📧

# --- Device ---
# "auto" picks GPU if available, otherwise CPU. Can also force "cpu" or "cuda".
DEVICE=auto
